# ── Database ─────────────────────────────
DATABASE_URL=sqlite:///./mcp_agent.db

# ── LLM (Ollama) ─────────────────────────
# Model MUST support tool calling (e.g. llama3.1, qwen2.5) or MCP tools won't fire.
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434
# Leave blank for local Ollama. Set for Ollama Cloud (https://ollama.com).
OLLAMA_API_KEY=

# ── Agent ────────────────────────────────
SYSTEM_PROMPT=You are a helpful assistant. Use the available tools when relevant to the user's request.
MAX_TOKENS=8000
TOOL_TIMEOUT_SECONDS=30

# ── Server ───────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173
