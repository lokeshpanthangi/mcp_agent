# ── Database ─────────────────────────────
DATABASE_URL=sqlite:///./database/mcp_agent.db

# ── LLM (Ollama) ─────────────────────────
# Model MUST support tool calling (e.g. llama3.1, qwen2.5) or MCP tools won't fire.
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434
# Leave blank for local Ollama. Set for Ollama Cloud (https://ollama.com).
OLLAMA_API_KEY=

# ── Agent ────────────────────────────────
# System prompt lives in backend/agent/prompts.py (it is content, not config).
MAX_TOKENS=8000
TOOL_TIMEOUT_SECONDS=30

# ── Server ───────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173

# ── OAuth (MCP connectors) ───────────────
# Where the OAuth callback is reachable (must match what providers redirect to).
PUBLIC_BASE_URL=http://localhost:8000
# Where to send the user's browser back to after connecting.
FRONTEND_URL=http://localhost:5173
